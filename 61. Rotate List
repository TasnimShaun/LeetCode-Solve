class Solution {
public:
    ListNode* rotateRight(ListNode* head, int k)
    
     {
        if (!head || !head->next || k == 0) 
        return head;

        int n = 1;
        ListNode* tail = head;

        while (tail->next)
         {
            tail = tail->next;
            n++;
        }

        tail->next = head;

        k = k % n;

        int steps = n - k - 1;
        ListNode* newTail_node = head;

        while (steps--) 
        {
            newTail_node = newTail_node->next;
        }

        ListNode* newHead_node = newTail_node->next;

        newTail_node->next = nullptr;

        return newHead_node; 
    }
};
