class Solution {
public:
    int maxRotateFunction(vector<int>& num) {
        
         int sum = 0, x = 0;
        int n = num.size();

        for (int i = 0; i < n; i++) {
            sum += num[i];
            x += i * num[i];
        }

        int maximum = x;

        for (int i = 1; i < n; i++) {
            x += sum - n * num[n - i];
            maximum = max(maximum, x);
        }

        return maximum;
    }
};
