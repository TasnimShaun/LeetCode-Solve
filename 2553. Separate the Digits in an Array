class Solution {
public:
    vector<int> separateDigits(vector<int>& nums) 
      {
        
        vector<int> result;

        for (int value: nums) 
            {

            string s = to_string(value);

            for (char ch : s) 
            {

                result.push_back(ch - '0');
            }
        }

        return result;
    }
};
