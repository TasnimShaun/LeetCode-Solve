class Solution {
public:
    int countSubarrays(vector<int>& num) {
        int count=0;
        int n = num.size();
        for(int i=0;i<n-2;i++)
        {
            if((num[i] + num[i+2])*2 == num[i+1])
            {
                count++;
            }
        }
        return count;
        
    }
};
