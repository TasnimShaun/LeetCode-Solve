class Solution {
public:
    bool isGood(vector<int>& num)
     {
        sort(num.begin(), num.end());

        int n = num.size();

        int mx = num[n - 1];

        if (n != mx + 1)
            return false;

        for (int i = 0; i < n - 1; i++)
         {

            if (num[i] != i + 1)
                return false;
        }

        return num[n - 1] == mx;
    }
};
