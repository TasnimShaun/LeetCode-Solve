class Solution {
public:
    long long zeroFilledSubarray(vector<int>& nums) {
        long long ans =0;
        long long zero =0;
        for( int  num : nums)
        {
            if( num== 0)
            {
                zero ++;
                ans += zero;
            }
            else
            {
                zero = 0;
            }

        }
        return ans;
        
    }
};
