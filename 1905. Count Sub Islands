class Solution {
public:
         int row, col;
         bool vis[505][505];
         bool flag;
         vector<pair<int,int>> direction = {{0,1},{0,-1},{-1,0},{1,0}};
         bool valid(int i , int j)
         {
            if(i<0 || i>=row || j<0 || j>=col)
               return false;
            return true;
         }


         void dfs(int source_i,int source_j,vector<vector<int>>& grid1, vector<vector<int>>& grid2)
         {
            vis[source_i][source_j] = true;
             if(grid1[source_i][source_j] == 0)
               flag = false;

             for(int i =0;i<4;i++)
             {
                int child_i = source_i + direction[i].first;
                int child_j = source_j + direction[i].second;
                if(valid(child_i,child_j) && !vis[child_i][child_j] && grid2[child_i][child_j] == 1)
                dfs(child_i,child_j,grid1,grid2);
             }
         }


    int countSubIslands(vector<vector<int>>& grid1, vector<vector<int>>& grid2) {

        row = grid1.size();
        col = grid1[0].size();
        memset(vis,false,sizeof(vis));
        int count =0;
    for(int i=0;i<row;i++)
        for(int j=0;j<col;j++)
                {
                    if(!vis[i][j] && grid2[i][j] == 1)
                    {
                        flag = true;
                    dfs(i,j,grid1,grid2);
                    if(flag == true)
                    count++;
                    }
                }
                return count;

        
    }
};
