class MyStack {
public:
 queue<int>q;

    MyStack() {
        
    }
    
    void push(int x) {
        q.push(x);
    }
    
    int pop() {
       queue<int>q2;
        int value;
       while(!q.empty()) 
       {
       value = q.front();
        q.pop();
        if(q.empty() == true)
        break;
        q2.push(value);
       }
       q = q2;
       return value;
    }
    
    int top() {
      return q.back(); 
    }
    
    bool empty() {
        return q.empty();
    }
};
