class Solution {
public:
    int rotatedDigits(int n) {
        int count = 0;
        for (int i = 1; i <= n; i++) {
            int number = i;
            bool valid = true;
            bool x = false;
            
            while (number > 0) {
                int digit = number % 10;
                
                if (digit == 3 || digit == 4 || digit == 7) {
                    valid = false;
                    break;
                }
                
                if (digit == 2 || digit == 5 || digit == 6 || digit == 9) {
                    x = true;
                }
                
                number /= 10;
            }
            
            if (valid && x) {
                count++;
            }
        }
        return count;
    }
    
};
