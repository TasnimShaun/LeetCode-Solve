class Solution {
public:
    vector<int> inorderTraversal(TreeNode* root) {

        vector<int> result;
        stack<TreeNode*> st;

        TreeNode* curr = root;

        while (curr != nullptr || !st.empty()) {

            // Go as left as possible
            while (curr != nullptr) {
                st.push(curr);
                curr = curr->left;
            }

            curr = st.top();
            st.pop();

            // Visit node
            result.push_back(curr->val);

            // Move to right subtree
            curr = curr->right;
        }

        return result;
    }
};
