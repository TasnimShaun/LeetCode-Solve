class Solution {
public:
    int findNumbers(vector<int>& num)
     {
        int count =0;
        for( int value : num)
        {
            int digit = 0;
            if( value == 0)
            {
                digit =1;
            }
            else
            {
                while( value!=0)
                {
                    digit++;
                    value /= 10;
                }
            }
            if(digit % 2 == 0)
            {
                count++;
            }
        }
        return count;


    }
};
