import pandas as pd

def second_highest_salary(employee: pd.DataFrame) -> pd.DataFrame:

    # Remove duplicate salaries and sort in descending order
    salaries = employee['salary'].drop_duplicates().sort_values(ascending=False)

    # Get the second highest salary if it exists,
    # otherwise return None
    second_highest = salaries.iloc[1] if len(salaries) > 1 else None

    # Return the result in the required DataFrame format
    return pd.DataFrame({
        'SecondHighestSalary': [second_highest]
    })
